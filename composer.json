{
    "name": "your-org/precommit-hooks",
    "description": "Reusable Git pre-commit hooks for Laravel projects",
    "type": "library",
    "autoload": {
        "psr-4": {
            "YourOrg\\Precommit\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php install.php"
        ],
        "post-update-cmd": [
            "php install.php"
        ]
    },
    "require": {}
}
